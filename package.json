			"types": "./src/context.ts",
			"import": "./dist/context.mjs"
		},
		"./link": {
			"types": "./src/link.tsx",
			"import": "./dist/link.mjs"
		},
		"./navigate": {
			"types": "./src/navigate.ts",
			"import": "./dist/navigate.mjs"
		},
		"./outlet": {
			"types": "./src/outlet.tsx",
			"import": "./dist/outlet.mjs"
		},
		"./path": {
			"types": "./src/path.ts",
			"import": "./dist/path.mjs"
		},
		"./route": {
			"types": "./src/route.ts",
			"import": "./dist/route.mjs"
		},
		"./router": {
			"types": "./src/router.tsx",
			"import": "./dist/router.mjs"
