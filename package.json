		"babel-preset-solid": "2.0.0-beta.4",
		"bun-types": "1.3.11",
		"eslint": "^10.1.0",
		"tsdown": "^0.21.4",
		"typescript": "^6.0.2",
		"valibot": "^1.3.1"
	}
